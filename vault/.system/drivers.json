{
  "drivers": [
    {
      "name": "vault_fs",
      "transport": "stdio",
      "command": "{PYTHON}",
      "args": [
        "{ORCHESTRATOR_ROOT}/tools/vault_fs_server.py",
        "{VAULT_PATH}"
      ],
      "env_allow": [],
      "tags": [],
      "enabled": true
    },
    {
      "name": "search",
      "transport": "stdio",
      "command": "{PYTHON}",
      "args": [
        "{ORCHESTRATOR_ROOT}/tools/search_server.py"
      ],
      "env_allow": ["SERPER_API_KEY", "TAVILY_API_KEY"],
      "tags": [],
      "enabled": false
    },
    {
      "name": "margin",
      "transport": "stdio",
      "command": "{PYTHON}",
      "args": [
        "{ORCHESTRATOR_ROOT}/tools/margin_server.py",
        "{VAULT_PATH}"
      ],
      "env_allow": [],
      "tags": [],
      "enabled": true
    },
    {
      "name": "docs",
      "transport": "stdio",
      "command": "{PYTHON}",
      "args": [
        "{ORCHESTRATOR_ROOT}/tools/docs_server.py",
        "{VAULT_PATH}"
      ],
      "env_allow": [],
      "tags": [],
      "enabled": true
    },
    {
      "name": "gmail",
      "transport": "stdio",
      "command": "{PYTHON}",
      "args": [
        "{ORCHESTRATOR_ROOT}/tools/gmail_server.py"
      ],
      "env_allow": ["GMAIL_CLIENT_ID", "GMAIL_CLIENT_SECRET", "BLACKBOX_GMAIL_SEND_ENABLED"],
      "tags": [],
      "enabled": false
    },
    {
      "name": "fs",
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "{VAULT_PATH}"],
      "env_allow": [],
      "tags": [],
      "enabled": false
    },
    {
      "name": "shell",
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "@anthropic-ai/mcp-server-shell"],
      "env_allow": [],
      "tags": ["exec"],
      "enabled": false
    }
  ]
}
