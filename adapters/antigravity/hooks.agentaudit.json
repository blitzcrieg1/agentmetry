{
  "PreToolUse": [
    {
      "matcher": "run_command",
      "hooks": [
        {
          "type": "command",
          "command": "python scripts/agentaudit_ingest.py antigravity hook PreToolUse",
          "timeout": 10
        }
      ]
    }
  ],
  "PostToolUse": [
    {
      "matcher": "run_command",
      "hooks": [
        {
          "type": "command",
          "command": "python scripts/agentaudit_ingest.py antigravity hook PostToolUse",
          "timeout": 10
        }
      ]
    }
  ],
  "Stop": [
    {
      "type": "command",
      "command": "python scripts/agentaudit_ingest.py antigravity hook Stop",
      "timeout": 10
    }
  ]
}
