{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "python scripts/agentmetry_ingest.py codex hook SessionStart",
            "timeout": 10,
            "statusMessage": "Agentmetry session"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python scripts/agentmetry_ingest.py codex hook PreToolUse",
            "timeout": 10,
            "statusMessage": "Agentmetry pre-tool"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python scripts/agentmetry_ingest.py codex hook PermissionRequest",
            "timeout": 10,
            "statusMessage": "Agentmetry permission"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python scripts/agentmetry_ingest.py codex hook PostToolUse",
            "timeout": 10,
            "statusMessage": "Agentmetry post-tool"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python scripts/agentmetry_ingest.py codex hook Stop",
            "timeout": 10,
            "statusMessage": "Agentmetry stop"
          }
        ]
      }
    ]
  }
}
