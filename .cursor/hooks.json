{
  "version": 1,
  "hooks": {
    "sessionStart": [
      { "command": "python scripts/agentaudit_ingest.py hook sessionStart" }
    ],
    "sessionEnd": [
      { "command": "python scripts/agentaudit_ingest.py hook sessionEnd" }
    ],
    "stop": [
      { "command": "python scripts/agentaudit_ingest.py hook stop" }
    ],
    "beforeShellExecution": [
      { "command": "python scripts/agentaudit_ingest.py hook beforeShellExecution" }
    ],
    "afterShellExecution": [
      { "command": "python scripts/agentaudit_ingest.py hook afterShellExecution" }
    ],
    "beforeMCPExecution": [
      { "command": "python scripts/agentaudit_ingest.py hook beforeMCPExecution" }
    ],
    "afterMCPExecution": [
      { "command": "python scripts/agentaudit_ingest.py hook afterMCPExecution" }
    ],
    "preToolUse": [
      { "command": "python scripts/agentaudit_ingest.py hook preToolUse" }
    ],
    "postToolUse": [
      { "command": "python scripts/agentaudit_ingest.py hook postToolUse" }
    ],
    "postToolUseFailure": [
      { "command": "python scripts/agentaudit_ingest.py hook postToolUseFailure" }
    ]
  }
}
