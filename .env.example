# Agentmetry environment configuration
# Copy to apps/orchestrator/.env and adjust as needed

# Vault path (local dev: relative to repo root)
AGENTMETRY_VAULT_PATH=../../vault

# Vector DB (optional — semantic memory works without Qdrant)
AGENTMETRY_QDRANT_URL=http://localhost:6333

# LLM Provider — gemini | ollama | mock
AGENTMETRY_LLM_PROVIDER=gemini
# Mock output never runs implicitly: opt in for dry runs (archived as mock-dry-run)
AGENTMETRY_ALLOW_MOCK=false
AGENTMETRY_GEMINI_MODEL=gemini-2.5-flash-lite
AGENTMETRY_GEMINI_EMBEDDING_MODEL=gemini-embedding-2
AGENTMETRY_EMBEDDING_DIMENSIONS=768
GEMINI_API_KEY=your_key_here

# Free tier presets:
#   gemini-2.5-flash-lite  → 10 RPM, 20 RPD  → limit=20, interval=6.5, reserve=8
#   gemini-3.1-flash-lite  → 15 RPM, 500 RPD → limit=500, interval=4.5, reserve=50
# Paid tier (example — tune from AI Studio table):
#   gemini-2.5-flash-lite  → 4K RPM, unlimited RPD → limit=100000, interval=0.2, reserve=50
#   gemini-2.5-flash       → 1K RPM, 10K RPD     → limit=10000, interval=0.1, reserve=100

# Ollama (local, optional if using Gemini)
AGENTMETRY_OLLAMA_BASE_URL=http://localhost:11434
AGENTMETRY_OLLAMA_MODEL=llama3.2
AGENTMETRY_EMBEDDING_MODEL=nomic-embed-text

# API auth (optional — leave empty for open local dev)
AGENTMETRY_API_KEY=

# Database — SQLite by default; Postgres when running via docker compose
AGENTMETRY_USE_POSTGRES=false
AGENTMETRY_DATABASE_URL=sqlite:///./data/telemetry.db
AGENTMETRY_POSTGRES_URL=postgresql://agentmetry:agentmetry@localhost:5432/agentic_os

# Safety rails
AGENTMETRY_APPROVAL_THRESHOLD=0.9
AGENTMETRY_COST_ALERT_THRESHOLD=1.0
AGENTMETRY_CONTEXT_WINDOW_TOKENS=1048576

# Gemini free-tier quota savers — tune to your model's RPM/RPD in AI Studio
AGENTMETRY_GEMINI_HEALTH_PROBE=false
AGENTMETRY_GEMINI_HEALTH_CACHE_SECONDS=300
AGENTMETRY_GEMINI_FLASH_MIN_INTERVAL_SECONDS=6.5
AGENTMETRY_GEMINI_EMBED_MIN_INTERVAL_SECONDS=0.7
# Daily generateContent budget; autonomous runs pause once only the
# interactive reserve remains, manual runs are never blocked
AGENTMETRY_GEMINI_FLASH_DAILY_LIMIT=20
AGENTMETRY_GEMINI_FLASH_INTERACTIVE_RESERVE=8
AGENTMETRY_STARTUP_VAULT_INDEX=true
AGENTMETRY_STARTUP_INDEX_SKIP_UNCHANGED=true

# Dashboard (build-time for Docker)
NEXT_PUBLIC_ORCHESTRATOR_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_AGENTMETRY_API_KEY=
