# Agentmetry SIEM — copy to apps/orchestrator/.env
# Never commit .env — it is gitignored

# Demo MCP vault (doctor + vault_fs driver); relative to apps/orchestrator/
AGENTMETRY_VAULT_PATH=../../vault

# Operator identity (stamped on every canonical event)
AGENTMETRY_OPERATOR_ID=local

# Optional API key for ingest/tail/export endpoints
AGENTMETRY_API_KEY=

# Audit trail (default: enabled, file sink)
AGENTMETRY_AUDIT_EXPORT_ENABLED=1
AGENTMETRY_AUDIT_SINK=file

# Hook boundary — log (audit only), block (deny matching tools/secrets), disable
AGENTMETRY_TOOL_POLICY_MODE=log
AGENTMETRY_DLP_MODE=log

# Optional forwarders (see docs/integrations/)
# AGENTMETRY_AUDIT_WEBHOOK_URL=
# AGENTMETRY_AUDIT_ELASTIC_URL=
# AGENTMETRY_AUDIT_SPLUNK_HEC_URL=

# Dashboard build-time (Docker / static export)
NEXT_PUBLIC_ORCHESTRATOR_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
