# BLACKBOX environment configuration
# Copy to apps/orchestrator/.env and adjust as needed

# Vault path (local dev: relative to repo root)
BLACKBOX_VAULT_PATH=../../vault

# Vector DB (optional — semantic memory works without Qdrant)
BLACKBOX_QDRANT_URL=http://localhost:6333

# LLM Provider — gemini | ollama | mock
BLACKBOX_LLM_PROVIDER=gemini
# Mock output never runs implicitly: opt in for dry runs (archived as mock-dry-run)
BLACKBOX_ALLOW_MOCK=false
BLACKBOX_GEMINI_MODEL=gemini-2.5-flash-lite
BLACKBOX_GEMINI_EMBEDDING_MODEL=gemini-embedding-2
BLACKBOX_EMBEDDING_DIMENSIONS=768
GEMINI_API_KEY=your_key_here

# Free tier presets:
#   gemini-2.5-flash-lite  → 10 RPM, 20 RPD  → limit=20, interval=6.5, reserve=8
#   gemini-3.1-flash-lite  → 15 RPM, 500 RPD → limit=500, interval=4.5, reserve=50
# Paid tier (example — tune from AI Studio table):
#   gemini-2.5-flash-lite  → 4K RPM, unlimited RPD → limit=100000, interval=0.2, reserve=50
#   gemini-2.5-flash       → 1K RPM, 10K RPD     → limit=10000, interval=0.1, reserve=100

# Ollama (local, optional if using Gemini)
BLACKBOX_OLLAMA_BASE_URL=http://localhost:11434
BLACKBOX_OLLAMA_MODEL=llama3.2
BLACKBOX_EMBEDDING_MODEL=nomic-embed-text

# API auth (optional — leave empty for open local dev)
BLACKBOX_API_KEY=

# Database — SQLite by default; Postgres when running via docker compose
BLACKBOX_USE_POSTGRES=false
BLACKBOX_DATABASE_URL=sqlite:///./data/telemetry.db
BLACKBOX_POSTGRES_URL=postgresql://blackbox:blackbox@localhost:5432/agentic_os

# Safety rails
BLACKBOX_APPROVAL_THRESHOLD=0.9
BLACKBOX_COST_ALERT_THRESHOLD=1.0
BLACKBOX_CONTEXT_WINDOW_TOKENS=1048576

# Gemini free-tier quota savers — tune to your model's RPM/RPD in AI Studio
BLACKBOX_GEMINI_HEALTH_PROBE=false
BLACKBOX_GEMINI_HEALTH_CACHE_SECONDS=300
BLACKBOX_GEMINI_FLASH_MIN_INTERVAL_SECONDS=6.5
BLACKBOX_GEMINI_EMBED_MIN_INTERVAL_SECONDS=0.7
# Daily generateContent budget; autonomous runs pause once only the
# interactive reserve remains, manual runs are never blocked
BLACKBOX_GEMINI_FLASH_DAILY_LIMIT=20
BLACKBOX_GEMINI_FLASH_INTERACTIVE_RESERVE=8
BLACKBOX_STARTUP_VAULT_INDEX=true
BLACKBOX_STARTUP_INDEX_SKIP_UNCHANGED=true

# Dashboard (build-time for Docker)
NEXT_PUBLIC_ORCHESTRATOR_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_BLACKBOX_API_KEY=
