# BLACKBOX environment configuration
# Copy to .env and adjust as needed

# Vault path (local dev: relative to repo root)
BLACKBOX_VAULT_PATH=./vault

# Vector DB
BLACKBOX_QDRANT_URL=http://localhost:6333

# LLM Provider — gemini | ollama | mock
BLACKBOX_LLM_PROVIDER=gemini
BLACKBOX_GEMINI_MODEL=gemini-2.5-flash
BLACKBOX_GEMINI_EMBEDDING_MODEL=gemini-embedding-2
BLACKBOX_EMBEDDING_DIMENSIONS=768
GEMINI_API_KEY=your_key_here

# Ollama (local, optional if using Gemini)
BLACKBOX_OLLAMA_BASE_URL=http://localhost:11434
BLACKBOX_OLLAMA_MODEL=llama3.2
BLACKBOX_EMBEDDING_MODEL=nomic-embed-text — set USE_POSTGRES=true when running via docker compose
BLACKBOX_USE_POSTGRES=false
BLACKBOX_DATABASE_URL=sqlite:///./data/telemetry.db
BLACKBOX_POSTGRES_URL=postgresql://blackbox:blackbox@localhost:5432/agentic_os

# Safety rails
BLACKBOX_APPROVAL_THRESHOLD=0.9
BLACKBOX_COST_ALERT_THRESHOLD=1.0

# Dashboard (build-time for Docker)
NEXT_PUBLIC_ORCHESTRATOR_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
