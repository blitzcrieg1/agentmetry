# Agentmetry — zero-cloud dogfood profile
# Copy to apps/orchestrator/.env for audit-only runs (no Gemini, no Qdrant).
#
#   copy apps\orchestrator\.env.agentmetry-demo apps\orchestrator\.env
#   scripts\agentmetry.bat start
#
# Generates real tool_called + approval_* events via mock LLM. Draft text is
# placeholder (mock-dry-run) — fine for JSONL/replay verification, not for Loom.
# Switch to Gemini or Ollama for the Loom take — see docs/agentmetry-dependency-audit.md Profile B.

# --- audit layer (the product) ---
AGENTMETRY_OPERATOR_ID=home-lab
AGENTMETRY_AUDIT_EXPORT_ENABLED=1
AGENTMETRY_AUDIT_SINK=file
# Log shell commands from Tier B hooks (Cursor/Claude/Codex/Antigravity) in JSONL + dashboard
AGENTMETRY_AUDIT_LOG_COMMANDS=1

# --- runtime, no cloud LLM ---
AGENTMETRY_LLM_PROVIDER=mock
AGENTMETRY_ALLOW_MOCK=1
AGENTMETRY_VAULT_PATH=../../vault

# Faster boot for audit-only (no semantic index)
AGENTMETRY_STARTUP_VAULT_INDEX=false

# Not required for audit dogfood — leave unset / empty:
# GEMINI_API_KEY=
# AGENTMETRY_QDRANT_URL=
# AGENTMETRY_USE_POSTGRES=false  (default)
