# BLACKBOX orchestrator — copy to .env and fill in secrets
# cp apps/orchestrator/.env.example apps/orchestrator/.env  (or copy on Windows)
# Never commit .env — it is gitignored

BLACKBOX_LLM_PROVIDER=gemini
BLACKBOX_GEMINI_MODEL=gemini-2.5-flash-lite
BLACKBOX_GEMINI_FLASH_DAILY_LIMIT=100000
BLACKBOX_GEMINI_FLASH_MIN_INTERVAL_SECONDS=0.2
BLACKBOX_GEMINI_FLASH_INTERACTIVE_RESERVE=50
GEMINI_API_KEY=paste-your-key-here
BLACKBOX_VAULT_PATH=C:/Users/you/Projects/agentic-os/vault

# Optional — leave empty until you need them
SERPER_API_KEY=
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
BLACKBOX_API_KEY=

# More tuning (SQLite, Ollama, Postgres, budget rails): see repo root .env.example
