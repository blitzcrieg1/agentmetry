# Agentmetry orchestrator — copy to .env and adjust
# cp apps/orchestrator/.env.example apps/orchestrator/.env
# Never commit .env — it is gitignored

# Demo MCP vault path (relative to this directory)
AGENTMETRY_VAULT_PATH=../../vault

AGENTMETRY_OPERATOR_ID=local
AGENTMETRY_API_KEY=

# Hook boundary — log | block | disable
AGENTMETRY_TOOL_POLICY_MODE=log
AGENTMETRY_DLP_MODE=log

# Audit export (JSONL + SQLite index)
AGENTMETRY_AUDIT_EXPORT_ENABLED=1
AGENTMETRY_AUDIT_SINK=file

# More tuning: see repo root .env.example and docs/agentmetry-dogfood-checklist.md
