# Agentmetry orchestrator — copy to .env and fill in secrets
# cp apps/orchestrator/.env.example apps/orchestrator/.env  (or copy on Windows)
# Never commit .env — it is gitignored

AGENTMETRY_LLM_PROVIDER=gemini
AGENTMETRY_GEMINI_MODEL=gemini-2.5-flash-lite
AGENTMETRY_GEMINI_FLASH_DAILY_LIMIT=100000
AGENTMETRY_GEMINI_FLASH_MIN_INTERVAL_SECONDS=0.2
AGENTMETRY_GEMINI_FLASH_INTERACTIVE_RESERVE=50
GEMINI_API_KEY=paste-your-key-here
AGENTMETRY_VAULT_PATH=C:/Users/you/Projects/agentic-os/vault

# Optional — leave empty until you need them
SERPER_API_KEY=
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
AGENTMETRY_API_KEY=

# More tuning (SQLite, Ollama, Postgres, budget rails): see repo root .env.example
