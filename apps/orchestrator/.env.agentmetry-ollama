# ============================================================================
# Agentmetry — air-gapped profile (Ollama inference, local audit)
# ============================================================================
# The security/OSS hero path: inference runs on a LOCAL Ollama model, so no
# prompt ever leaves the machine, and the audit trail (events.db + JSONL) is
# local by default. Two pipes, both on-box.
#
# Prerequisites (one time):
#   1. Install Ollama       → https://ollama.com/download
#   2. Pull a model         → ollama pull llama3.2
#   3. Ollama serves on http://localhost:11434 by default
#
# Use it:
#   copy apps\orchestrator\.env.agentmetry-ollama apps\orchestrator\.env
#   scripts\agentmetry.bat start
#
# Privacy note:
#   - Pipe 1 (inference): prompts go to your LOCAL Ollama — never to a cloud API.
#   - Pipe 2 (audit): tool calls, denials, approvals → events.db + audit-forward.jsonl,
#     both local. Nothing is forwarded off-box unless you set a network sink.
#   - Tool arguments are HASHED in the audit record, not stored in plaintext.
# ============================================================================

# --- inference (Pipe 1): local, no cloud -----------------------------------
AGENTMETRY_LLM_PROVIDER=ollama
AGENTMETRY_OLLAMA_BASE_URL=http://localhost:11434
AGENTMETRY_OLLAMA_MODEL=llama3.2
# If boot complains about an unknown var name, confirm the exact keys in
# core/config.py — this profile uses the documented AGENTMETRY_OLLAMA_* names.

# --- no cloud keys ----------------------------------------------------------
# GEMINI_API_KEY intentionally absent. Do not set it in this profile.

# --- audit layer (Pipe 2): the product -------------------------------------
AGENTMETRY_OPERATOR_ID=home-lab
AGENTMETRY_AUDIT_EXPORT_ENABLED=1
AGENTMETRY_AUDIT_SINK=file
# AGENTMETRY_AUDIT_EXPORT_PATH defaults to data/audit-forward.jsonl

# --- runtime ----------------------------------------------------------------
AGENTMETRY_VAULT_PATH=../../vault
# Skip semantic vault indexing for a fast, dependency-light boot. The audit
# demo (audit_demo skill) reads a note by path and needs no RAG index.
AGENTMETRY_STARTUP_VAULT_INDEX=false

# --- everything else OFF ----------------------------------------------------
# No Qdrant, no PostgreSQL, no Gmail, no search keys, no Telegram.
# Dashboard is optional (approve via UI or API); it is not required to run.
