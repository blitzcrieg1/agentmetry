# AgentAudit — zero-cloud dogfood profile
# Copy to apps/orchestrator/.env for audit-only runs (no Gemini, no Qdrant).
#
#   copy apps\orchestrator\.env.agentaudit-demo apps\orchestrator\.env
#   scripts\blackbox.bat start
#
# Generates real tool_called + approval_* events via mock LLM. Draft text is
# placeholder (mock-dry-run) — fine for JSONL/replay verification, not for Loom.
# Switch to Gemini or Ollama for the Loom take — see docs/agentaudit-dependency-audit.md Profile B.

# --- audit layer (the product) ---
BLACKBOX_OPERATOR_ID=home-lab
BLACKBOX_AUDIT_EXPORT_ENABLED=1
BLACKBOX_AUDIT_SINK=file

# --- runtime, no cloud LLM ---
BLACKBOX_LLM_PROVIDER=mock
BLACKBOX_ALLOW_MOCK=1
BLACKBOX_VAULT_PATH=../../vault

# Faster boot for audit-only (no semantic index)
BLACKBOX_STARTUP_VAULT_INDEX=false

# Not required for audit dogfood — leave unset / empty:
# GEMINI_API_KEY=
# BLACKBOX_QDRANT_URL=
# BLACKBOX_USE_POSTGRES=false  (default)
