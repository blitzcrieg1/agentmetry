// Grafana Alloy — tail Agentmetry JSONL → Loki (homelab stack).
// Mount repo apps/orchestrator/data at /var/log/agentmetry in docker-compose.loki.yml.

logging {
  level = "info"
}

local.file_match "agent_audit" {
  path_targets = [{
    __path__ = "/var/log/agentmetry/audit-forward.jsonl",
    job        = "agentmetry",
  }]
}

loki.source.file "agent_audit" {
  targets    = local.file_match.agent_audit.targets
  forward_to = [loki.process.agent_audit.receiver]
}

loki.process "agent_audit" {
  // The file sink writes hash-chained envelopes: {"trail":{...},"event":{...}}.
  // Unwrap them so Loki stores the canonical event, which is the same shape the
  // webhook, Elastic and Splunk sinks send. Without this every extraction below
  // reads the envelope's top level, finds nothing, and every documented query
  // returns empty.
  //
  // "event || @" returns the nested event for a chained line and the whole
  // document for a legacy unchained line, so both shapes come out canonical and
  // no line is dropped.
  stage.json {
    expressions = {
      canonical = "event || @",
    }
  }

  stage.output {
    source = "canonical"
  }

  stage.json {
    expressions = {
      action_type    = "action.type",
      action_outcome = "action.outcome",
      correlation_id = "correlation_id",
      actor_id       = "actor.id",
      tool_qualified = "tool.qualified",
      source_topic   = "source_topic",
    }
  }

  stage.labels {
    values = {
      action_type    = "",
      action_outcome = "",
    }
  }

  forward_to = [loki.write.default.receiver]
}

loki.write "default" {
  endpoint {
    url = "http://loki:3100/loki/api/v1/push"
  }
}
