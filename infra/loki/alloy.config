// Grafana Alloy — tail AgentAudit JSONL → Loki (homelab stack).
// Mount repo apps/orchestrator/data at /var/log/agent-audit in docker-compose.loki.yml.

logging {
  level = "info"
}

local.file_match "agent_audit" {
  path_targets = [{
    __path__ = "/var/log/agent-audit/audit-forward.jsonl",
    job        = "agent-audit",
  }]
}

loki.source.file "agent_audit" {
  targets    = local.file_match.agent_audit.targets
  forward_to = [loki.process.agent_audit.receiver]
}

loki.process "agent_audit" {
  stage.json {
    expressions = {
      action_type    = "action.type",
      action_outcome = "action.outcome",
      correlation_id = "correlation_id",
      actor_id       = "actor.id",
      tool_qualified = "tool.qualified",
      source_topic   = "source_topic",
    }
  }

  stage.labels {
    values = {
      action_type    = "",
      action_outcome = "",
    }
  }

  forward_to = [loki.write.default.receiver]
}

loki.write "default" {
  endpoint {
    url = "http://loki:3100/loki/api/v1/push"
  }
}
